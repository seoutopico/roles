{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/seoutopico/roles/schemas/role.schema.json",
  "title": "Role Package Metadata",
  "type": "object",
  "required": [
    "id",
    "name",
    "category",
    "version",
    "status",
    "specificity_level",
    "last_reviewed",
    "freshness_policy",
    "target_users",
    "core_capabilities",
    "anti_generic_scope",
    "sources_required"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
    },
    "name": {
      "type": "string",
      "minLength": 8
    },
    "category": {
      "type": "string",
      "pattern": "^[a-z0-9-]+(/[a-z0-9-]+)*$"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "status": {
      "type": "string",
      "enum": ["draft", "active", "needs-review", "deprecated"]
    },
    "specificity_level": {
      "type": "string",
      "enum": ["medium", "high", "very-high"]
    },
    "last_reviewed": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "freshness_policy": {
      "type": "string"
    },
    "target_users": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "core_capabilities": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 3
    },
    "anti_generic_scope": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 2
    },
    "sources_required": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 2
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}

